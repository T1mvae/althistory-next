# --- Notion integration ---
# 1. Create an integration at https://www.notion.so/my-integrations and copy its token.
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2. Your "🧩 Вселенные · Universes" database ID (already filled in for your workspace).
#    Open the database as a full page and copy the 32-char hash from the URL if it ever changes.
NOTION_UNIVERSES_DB_ID=84eb913e738e41b5a36de1bb52146dff

# 3. Public site URL (used for SEO / Open Graph absolute links).
NEXT_PUBLIC_SITE_URL=https://althistory.yourname.dev

# --- Optional: machine translation for missing languages (PT/UK) ---
# Leave empty to disable. If set, missing translations are generated at build time.
# Supported: "deepl" or "openai". Provide the matching key below.
TRANSLATE_PROVIDER=
DEEPL_API_KEY=
OPENAI_API_KEY=
